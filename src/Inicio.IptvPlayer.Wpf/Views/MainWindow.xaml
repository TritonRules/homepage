<Window x:Class="Inicio.IptvPlayer.Wpf.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:vlc="clr-namespace:LibVLCSharp.WPF;assembly=LibVLCSharp.WPF"
        mc:Ignorable="d"
        Title="Inicio IPTV"
        Height="760"
        Width="1300"
        Background="#121212"
        Foreground="#F1F1F1">
    <Grid Margin="12">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="370" />
            <ColumnDefinition Width="10" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <Border Grid.Column="0" Background="#1B1B1B" CornerRadius="8" Padding="10">
            <DockPanel>
                <StackPanel DockPanel.Dock="Top" Margin="0,0,0,8">
                    <TextBlock Text="Inicio IPTV" FontSize="20" FontWeight="SemiBold" />
                    <TextBlock Text="MVP Windows · WPF + LibVLCSharp" Foreground="#A8A8A8" />
                </StackPanel>

                <StackPanel DockPanel.Dock="Top" Orientation="Horizontal" Margin="0,0,0,8">
                    <Button Content="Importar M3U"
                            Command="{Binding ImportM3uCommand}"
                            Margin="0,0,8,0"
                            Padding="10,6" />
                    <Button Content="Importar XMLTV"
                            Command="{Binding ImportXmlTvCommand}"
                            Padding="10,6" />
                </StackPanel>

                <Grid DockPanel.Dock="Top" Margin="0,0,0,8">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <TextBox Grid.Column="0"
                             Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}"
                             Margin="0,0,8,0"
                             Padding="8,5"
                             VerticalContentAlignment="Center" />
                    <Button Grid.Column="1" Content="Buscar" Command="{Binding SearchCommand}" Padding="10,5" />
                </Grid>

                <ComboBox DockPanel.Dock="Top"
                          ItemsSource="{Binding Groups}"
                          SelectedItem="{Binding SelectedGroup}"
                          Margin="0,0,0,8" />

                <TextBlock DockPanel.Dock="Top"
                           Margin="0,0,0,8"
                           Foreground="#A8A8A8"
                           Text="{Binding TotalChannels, StringFormat=Canales encontrados: {0}}" />

                <ListBox ItemsSource="{Binding Channels}"
                         SelectedItem="{Binding SelectedChannel}"
                         ScrollViewer.CanContentScroll="True"
                         VirtualizingPanel.IsVirtualizing="True"
                         VirtualizingPanel.VirtualizationMode="Recycling"
                         BorderThickness="0"
                         Background="Transparent">
                    <ListBox.ItemsPanel>
                        <ItemsPanelTemplate>
                            <VirtualizingStackPanel />
                        </ItemsPanelTemplate>
                    </ListBox.ItemsPanel>
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <Border Padding="8" Margin="0,0,0,4" Background="#242424" CornerRadius="6">
                                <StackPanel>
                                    <TextBlock Text="{Binding Name}" FontWeight="SemiBold" />
                                    <TextBlock Text="{Binding GroupName}" Foreground="#A8A8A8" />
                                </StackPanel>
                            </Border>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>

                <Button DockPanel.Dock="Bottom"
                        Margin="0,8,0,0"
                        Content="Cargar más"
                        Command="{Binding LoadMoreCommand}" />
            </DockPanel>
        </Border>

        <Border Grid.Column="2" Background="#1B1B1B" CornerRadius="8" Padding="10">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="*" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <vlc:VideoView Grid.Row="0" MediaPlayer="{Binding Player}" />

                <StackPanel Grid.Row="1" Margin="0,10,0,0">
                    <TextBlock Text="{Binding NowProgram}" Margin="0,0,0,4" />
                    <TextBlock Text="{Binding NextProgram}" Margin="0,0,0,8" Foreground="#A8A8A8" />
                    <StackPanel Orientation="Horizontal">
                        <Button Content="Detener"
                                Command="{Binding StopPlaybackCommand}"
                                Margin="0,0,8,0"
                                Padding="10,6" />
                        <ComboBox Width="260"
                                  ItemsSource="{Binding AudioTracks}"
                                  SelectedItem="{Binding SelectedAudioTrack}" />
                    </StackPanel>
                    <TextBlock Text="{Binding Status}" Margin="0,8,0,0" Foreground="#A8A8A8" />
                </StackPanel>
            </Grid>
        </Border>
    </Grid>
</Window>
